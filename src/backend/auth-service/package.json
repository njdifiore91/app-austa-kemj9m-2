{
  "name": "@austa/auth-service",
  "version": "1.0.0",
  "description": "AUSTA SuperApp Authentication Service - HIPAA-compliant authentication and authorization",
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "nodemon -r tsconfig-paths/register src/index.ts",
    "build": "tsc",
    "test": "jest --detectOpenHandles",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:security": "jest --testMatch='**/*.security.test.ts'",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "audit": "npm audit --audit-level=moderate",
    "docker:build": "docker build -t austa/auth-service .",
    "docker:push": "docker push austa/auth-service"
  },
  "dependencies": {
    "@austa/shared": "file:../shared",
    "@auth0/auth0-spa-js": "^2.1.2",
    "@elastic/elasticsearch": "^8.11.0",
    "@opentelemetry/api": "^1.7.0",
    "@types/nodemailer": "^6.4.17",
    "bcrypt": "^5.1.1",
    "connect-redis": "^7.1.0",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-session": "^1.17.3",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "hpp": "^0.2.3",
    "http-status": "^1.7.3",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^7.6.7",
    "morgan": "^1.10.0",
    "newrelic": "^11.6.1",
    "nodemailer": "^6.10.0",
    "prom-client": "^15.1.0",
    "qrcode": "^1.5.4",
    "rate-limiter-flexible": "^4.0.1",
    "redis": "^4.6.12",
    "reflect-metadata": "^0.2.2",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@faker-js/faker": "^8.3.1",
    "@jest/globals": "^29.7.0",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.18.1",
    "@types/helmet": "^4.0.0",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^18.19.75",
    "@types/qrcode": "^1.5.5",
    "@types/winston": "^2.4.4",
    "eslint": "^8.56.0",
    "ioredis-mock": "^8.9.0",
    "jest": "^29.7.0",
    "jest-mock-extended": "^3.0.5",
    "lint-staged": "^15.2.0",
    "mongodb-memory-server": "^9.1.3",
    "nock": "^13.4.0",
    "nodemon": "^3.0.2",
    "prettier": "^3.1.1",
    "redis-mock": "^0.56.3",
    "sinon": "^17.0.1",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "coverageThreshold": {
      "global": {
        "branches": 85,
        "functions": 85,
        "lines": 85,
        "statements": 85
      }
    },
    "testMatch": [
      "**/__tests__/**/*.ts",
      "**/*.test.ts"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/austa/auth-service.git"
  },
  "keywords": [
    "authentication",
    "authorization",
    "oauth",
    "oidc",
    "hipaa",
    "security"
  ],
  "author": "AUSTA Healthcare",
  "license": "UNLICENSED",
  "private": true
}
