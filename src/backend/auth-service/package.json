{
  "name": "@austa/auth-service",
  "version": "1.0.0",
  "description": "AUSTA SuperApp Authentication Service - HIPAA-compliant authentication and authorization",
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn src/index.ts",
    "build": "tsc",
    "test": "jest --detectOpenHandles",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:security": "jest --testMatch='**/*.security.test.ts'",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "audit": "npm audit --audit-level=moderate",
    "docker:build": "docker build -t austa/auth-service .",
    "docker:push": "docker push austa/auth-service"
  },
  "dependencies": {
    "@auth0/auth0-spa-js": "^2.1.0",
    "@decorators/express": "^3.0.0",
    "@elastic/elasticsearch": "^8.0.0",
    "@opentelemetry/api": "^1.4.0",
    "bcrypt": "^5.1.0",
    "connect-redis": "^5.2.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.18.2",
    "express-rate-limit": "^6.9.0",
    "express-session": "^1.17.3",
    "express-validator": "^7.0.0",
    "helmet": "^7.0.0",
    "hpp": "^0.2.3",
    "http-status": "^1.6.2",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^7.0.0",
    "morgan": "^1.10.0",
    "newrelic": "^9.0.0",
    "prom-client": "^14.2.0",
    "rate-limiter-flexible": "^2.4.1",
    "redis": "^4.0.0",
    "reflect-metadata": "^0.2.2",
    "winston": "^3.10.0",
    "xss": "^1.0.15"
  },
  "devDependencies": {
    "@faker-js/faker": "^8.0.0",
    "@jest/globals": "^29.7.0",
    "@types/bcrypt": "^5.0.0",
    "@types/connect-redis": "^0.0.20",
    "@types/cors": "^2.8.13",
    "@types/express": "^4.17.17",
    "@types/express-session": "^1.17.7",
    "@types/helmet": "^4.0.0",
    "@types/hpp": "^0.2.2",
    "@types/jest": "^29.5.0",
    "@types/jsonwebtoken": "^9.0.8",
    "@types/morgan": "^1.9.4",
    "@types/node": "^18.15.0",
    "@types/redis": "^4.0.11",
    "@types/semver": "^7.5.8",
    "@types/whatwg-url": "^13.0.0",
    "eslint": "^8.48.0",
    "husky": "^8.0.3",
    "inversify": "^6.2.2",
    "ioredis-mock": "^8.9.0",
    "jest": "^29.6.0",
    "jest-mock-extended": "^3.0.4",
    "lint-staged": "^14.0.1",
    "mongodb-memory-server": "^8.13.0",
    "nock": "^13.3.8",
    "prettier": "^3.0.3",
    "redis-mock": "^0.56.3",
    "sinon": "^15.0.0",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^4.1.6"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "coverageThreshold": {
      "global": {
        "branches": 85,
        "functions": 85,
        "lines": 85,
        "statements": 85
      }
    },
    "testMatch": [
      "**/__tests__/**/*.ts",
      "**/*.test.ts"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/austa/auth-service.git"
  },
  "keywords": [
    "authentication",
    "authorization",
    "oauth",
    "oidc",
    "hipaa",
    "security"
  ],
  "author": "AUSTA Healthcare",
  "license": "UNLICENSED",
  "private": true
}
