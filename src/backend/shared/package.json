{
  "name": "@austa/shared",
  "version": "1.0.0",
  "description": "Shared utilities, types, and configurations for AUSTA services",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "private": true,
  "scripts": {
    "build": "npm run clean && npx tsc",
    "dev": "tsc --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "clean": "rimraf dist",
    "prepare": "npm run build",
    "prepack": "npm run build",
    "docs": "typedoc --out docs src",
    "check-types": "tsc --noEmit",
    "validate": "npm run lint && npm run test && npm run check-types"
  },
  "dependencies": {
    "aws-sdk": "^2.1550.0",
    "express": "^4.18.2",
    "http-status": "^1.7.3",
    "joi": "^17.12.1",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "node-cache": "^5.1.2",
    "uuid": "^9.0.1",
    "validator": "^13.11.0",
    "winston": "^3.11.0",
    "xss": "^1.0.14"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.18.1",
    "@types/jest": "^29.5.11",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/morgan": "^1.9.9",
    "@types/node": "^18.19.4",
    "@types/uuid": "^9.0.8",
    "@types/validator": "^13.11.7",
    "@typescript-eslint/eslint-plugin": "^6.19.1",
    "@typescript-eslint/parser": "^6.19.1",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "jest": "^29.7.0",
    "prettier": "^3.1.1",
    "rimraf": "^5.0.5",
    "ts-jest": "^29.1.1",
    "typedoc": "^0.25.7",
    "typescript": "^5.3.3"
  },
  "peerDependencies": {
    "express": "^4.18.2",
    "winston": "^3.11.0"
  },
  "workspaces": [
    "security-metrics",
    "session-manager"
  ]
}
