{
  "name": "@austa/api-gateway",
  "version": "1.0.0",
  "description": "Enterprise API Gateway for AUSTA SuperApp Platform",
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "PORT=8000 nodemon -r tsconfig-paths/register src/index.ts",
    "build": "tsc -p tsconfig.json",
    "test": "jest --runInBand --detectOpenHandles",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/**/*.ts --fix",
    "format": "prettier --write src/**/*.ts",
    "security:audit": "npm audit --audit-level=high",
    "docker:build": "docker build -t austa-api-gateway .",
    "docker:run": "docker run -p 8000:8000 austa-api-gateway"
  },
  "dependencies": {
    "@austa/shared": "file:../shared",
    "@nestjs/terminus": "^10.2.0",
    "@types/http-proxy": "^1.17.15",
    "@types/http-proxy-middleware": "^0.19.3",
    "cache-manager": "^5.3.2",
    "compression": "^1.7.4",
    "connect-redis": "^7.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-session": "^1.17.3",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "hpp": "^0.2.3",
    "http-proxy": "^1.18.1",
    "http-proxy-middleware": "^3.0.3",
    "http-status": "^1.7.3",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "node-vault": "^0.10.2",
    "opossum": "^8.1.3",
    "prom-client": "^14.2.0",
    "rate-limiter-flexible": "^4.0.1",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/helmet": "^4.0.0",
    "@types/hpp": "^0.2.5",
    "@types/jest": "^29.5.11",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/morgan": "^1.9.9",
    "@types/node": "^18.19.4",
    "@types/opossum": "^8.1.8",
    "@types/rate-limit-redis": "^1.7.4",
    "@types/winston": "^2.4.4",
    "eslint": "^8.56.0",
    "husky": "^8.0.3",
    "ioredis-mock": "^8.9.0",
    "jest": "^29.7.0",
    "nock": "^13.4.0",
    "nodemon": "^3.0.2",
    "prettier": "^3.1.1",
    "sinon": "^17.0.1",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!src/**/*.d.ts"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    }
  }
}
