{
  "name": "@austa/api-gateway",
  "version": "1.0.0",
  "description": "Enterprise API Gateway for AUSTA SuperApp Platform",
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "nodemon src/index.ts",
    "build": "tsc -p tsconfig.json",
    "test": "jest --runInBand --detectOpenHandles",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --coverageThreshold='{\"global\":{\"branches\":80,\"functions\":80,\"lines\":80,\"statements\":80}}'",
    "lint": "eslint src/**/*.ts --fix",
    "format": "prettier --write src/**/*.ts",
    "security:audit": "npm audit --audit-level=high",
    "docker:build": "docker build -t austa-api-gateway .",
    "docker:run": "docker run -p 3000:3000 austa-api-gateway"
  },
  "dependencies": {
    "@austa/shared": "1.0.0",
    "cache-manager": "^5.2.0",
    "compression": "^1.7.4",
    "connect-redis": "^7.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^6.9.0",
    "express-session": "^1.17.3",
    "express-validator": "^7.0.1",
    "helmet": "^7.0.0",
    "hpp": "^0.2.3",
    "http-status": "^1.6.2",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "node-vault": "^0.9.5",
    "prom-client": "^14.2.0",
    "winston": "^3.10.0"
  },
  "devDependencies": {
    "@types/circuit-breaker-js": "^0.0.5",
    "@types/cors": "^2.8.13",
    "@types/express": "^4.17.17",
    "@types/helmet": "^4.0.0",
    "@types/jest": "^29.5.0",
    "@types/jsonwebtoken": "^9.0.2",
    "@types/node": "^18.15.0",
    "@types/winston": "^2.4.4",
    "eslint": "^8.46.0",
    "ioredis-mock": "^8.9.0",
    "jest": "^29.6.2",
    "nock": "^13.3.8",
    "nodemon": "^3.0.1",
    "prettier": "^3.0.1",
    "sinon": "^15.0.0",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.1",
    "typescript": "^4.1.6"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!src/**/*.d.ts"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    }
  }
}
